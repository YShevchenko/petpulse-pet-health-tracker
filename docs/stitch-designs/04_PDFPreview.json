{"screenId":"3bd853375bb04d6caf9719aa10e0f468","projectId":"3066203392880845333","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Pet Passport Preview</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Manrope:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"surface-container-high\": \"#e6ebd2\",\n              \"on-secondary\": \"#ffffff\",\n              \"on-surface-variant\": \"#3f4943\",\n              \"on-secondary-fixed\": \"#001e2e\",\n              \"on-secondary-fixed-variant\": \"#064c6b\",\n              \"on-tertiary-container\": \"#fffbff\",\n              \"surface-container\": \"#ecf0d8\",\n              \"secondary-container\": \"#a3d8fe\",\n              \"on-primary-fixed-variant\": \"#005236\",\n              \"surface-container-highest\": \"#e0e5cc\",\n              \"primary-fixed-dim\": \"#86d7ad\",\n              \"on-error-container\": \"#93000a\",\n              \"on-primary-container\": \"#f5fff6\",\n              \"on-surface\": \"#191d0e\",\n              \"on-tertiary\": \"#ffffff\",\n              \"on-primary\": \"#ffffff\",\n              \"surface-bright\": \"#f7fce3\",\n              \"error-container\": \"#ffdad6\",\n              \"surface-variant\": \"#e0e5cc\",\n              \"inverse-on-surface\": \"#eff3da\",\n              \"surface-container-low\": \"#f2f6dd\",\n              \"secondary-fixed-dim\": \"#98cdf2\",\n              \"secondary-fixed\": \"#c7e7ff\",\n              \"error\": \"#ba1a1a\",\n              \"secondary\": \"#2b6485\",\n              \"outline\": \"#6f7a72\",\n              \"tertiary\": \"#735802\",\n              \"primary-container\": \"#30835f\",\n              \"primary\": \"#0b6947\",\n              \"on-error\": \"#ffffff\",\n              \"inverse-surface\": \"#2e3222\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"tertiary-container\": \"#8e711f\",\n              \"tertiary-fixed\": \"#ffdf96\",\n              \"on-background\": \"#191d0e\",\n              \"surface-dim\": \"#d8dcc4\",\n              \"on-tertiary-fixed-variant\": \"#5a4400\",\n              \"tertiary-fixed-dim\": \"#e7c268\",\n              \"on-primary-fixed\": \"#002113\",\n              \"background\": \"#f7fce3\",\n              \"surface\": \"#f7fce3\",\n              \"on-tertiary-fixed\": \"#251a00\",\n              \"inverse-primary\": \"#86d7ad\",\n              \"primary-fixed\": \"#a1f4c8\",\n              \"on-secondary-container\": \"#255f80\",\n              \"outline-variant\": \"#bec9c0\",\n              \"surface-tint\": \"#116c4a\"\n            },\n            fontFamily: {\n              \"headline\": [\"Plus Jakarta Sans\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Manrope\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .passport-shadow {\n            box-shadow: 0px 8px 24px rgba(25, 29, 14, 0.08);\n        }\n        .editorial-stack {\n            padding-bottom: clamp(100px, 20vh, 140px);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-surface antialiased\">\n<!-- TopAppBar Shell -->\n<nav class=\"fixed top-0 w-full z-50 bg-[#f7fce3]/80 dark:bg-emerald-950/80 backdrop-blur-md shadow-[0px_8px_24px_rgba(25,29,14,0.06)] flex justify-between items-center px-4 h-16 w-full\">\n<div class=\"flex items-center gap-3\">\n<button class=\"p-2 rounded-full hover:bg-[#e0e5cc]/50 dark:hover:bg-emerald-800/30 transition-colors active:scale-95 duration-200 text-[#0b6947] dark:text-[#a1f4c8]\">\n<span class=\"material-symbols-outlined\" data-icon=\"arrow_back\">arrow_back</span>\n</button>\n<span class=\"font-['Plus_Jakarta_Sans'] font-bold text-[#0b6947]\">Pet Passport</span>\n</div>\n<div class=\"flex items-center\">\n<button class=\"p-2 rounded-full hover:bg-[#e0e5cc]/50 dark:hover:bg-emerald-800/30 transition-colors active:scale-95 duration-200 text-[#0b6947] dark:text-[#a1f4c8]\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n</nav>\n<!-- Main Content Canvas -->\n<main class=\"pt-24 px-4 max-w-3xl mx-auto editorial-stack\">\n<!-- PDF Document Container -->\n<section class=\"bg-surface-container-lowest passport-shadow rounded-xl overflow-hidden border border-outline-variant/10\">\n<!-- Document Header -->\n<div class=\"p-8 bg-surface-container-low border-b border-outline-variant/20\">\n<div class=\"flex flex-col md:flex-row justify-between items-start md:items-center gap-6\">\n<div class=\"space-y-1\">\n<h1 class=\"font-headline text-3xl font-extrabold tracking-tight text-primary\">OFFICIAL PASSPORT</h1>\n<p class=\"font-label text-on-surface-variant text-sm tracking-widest uppercase\">Health Certification Document</p>\n</div>\n<div class=\"h-20 w-20 rounded-lg overflow-hidden border-2 border-surface-container-high bg-surface-variant flex items-center justify-center\">\n<img alt=\"Pet Profile\" class=\"w-full h-full object-cover\" data-alt=\"Close-up portrait of a friendly golden retriever with a soft focus natural outdoor background and warm sunlight\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBz9RfpZzaWc97bnmHTLVH5ygjt2CNXmKb0evPQruAOXdBnhYIZoJPN2KY5bYCZ4apEYNdM-uafmtZf8c0fM5FWcnm4rnhZEbDW5dOPyUfMJoubgeqOm7jfCkPteAxjdzFB7APKHKiF_9oGg7bsRC50xdjHxF-rI8NKHFx23gvM81FfeOauJHU11T-pGlp8xUK46eCRaC1rpYhvK-Xo-EGR1ns7zXovFfCSTvLfPAD_L9fDeeBicZm2HuEdOlBYd2BePUgD4ILU1GA\"/>\n</div>\n</div>\n</div>\n<!-- Pet Identity Section -->\n<div class=\"p-8 space-y-6\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-1.5 h-6 bg-primary rounded-full\"></div>\n<h2 class=\"font-headline text-xl font-bold text-on-surface\">Pet Identity</h2>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n<div class=\"space-y-4\">\n<div class=\"group\">\n<p class=\"font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1\">Name</p>\n<p class=\"font-headline text-lg font-semibold\">Cooper Richardson</p>\n</div>\n<div class=\"group\">\n<p class=\"font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1\">Species / Breed</p>\n<p class=\"font-headline text-lg font-semibold\">Canine / Golden Retriever</p>\n</div>\n<div class=\"group\">\n<p class=\"font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1\">Date of Birth</p>\n<p class=\"font-headline text-lg font-semibold\">May 14, 2021</p>\n</div>\n</div>\n<div class=\"bg-surface-container rounded-xl p-6 flex flex-col justify-center border border-outline-variant/20\">\n<div class=\"flex items-center gap-2 mb-2 text-primary\">\n<span class=\"material-symbols-outlined text-xl\" data-icon=\"qr_code_scanner\">qr_code_scanner</span>\n<p class=\"font-label text-xs uppercase tracking-widest font-bold\">Microchip Identity</p>\n</div>\n<p class=\"font-headline text-xl font-extrabold tracking-tighter text-on-primary-fixed-variant\">985 121 000 782 441</p>\n<div class=\"mt-4 pt-4 border-t border-outline-variant/20\">\n<div class=\"bg-white p-2 inline-block rounded-md\">\n<img alt=\"Security QR\" class=\"w-16 h-16 opacity-10 grayscale\" data-alt=\"Abstract geometric technical pattern representing a secure data encryption visual with clean lines\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCA8wRpT9pQ_uR7JuE8wCNoVgioHsA9nj3PbFI--njshdr29NY4tZOVBzVc4oPCUtrm6jXWnN_pBLAJIA0n3vjuDaRLqx_O1tBdnceKMvZ3hp40QM-nXcQoUxWKPIFILjr2vy_4e1cZYmQzFuXnviOgCx0T6qsS1EdJM1LGl1GuB0i4TCQ_QaVxJ2ipSEBHqU72_f4pU2DZxdaw_b7qo0N8K3-eKU0LIrfUlLCq3AGo8obuPRYlUU4Axl37WaR2tdKqAa456fKmdE0\"/>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- Vaccination History Section -->\n<div class=\"px-8 pb-12 space-y-6\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-1.5 h-6 bg-secondary rounded-full\"></div>\n<h2 class=\"font-headline text-xl font-bold text-on-surface\">Vaccination History</h2>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left border-separate border-spacing-0\">\n<thead>\n<tr class=\"bg-surface-container-high/50\">\n<th class=\"py-4 px-4 font-label text-xs uppercase tracking-widest text-on-surface-variant rounded-tl-lg\">Vaccine Name</th>\n<th class=\"py-4 px-4 font-label text-xs uppercase tracking-widest text-on-surface-variant\">Administered</th>\n<th class=\"py-4 px-4 font-label text-xs uppercase tracking-widest text-on-surface-variant rounded-tr-lg\">Valid Until</th>\n</tr>\n</thead>\n<tbody class=\"divide-y divide-outline-variant/10\">\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"py-4 px-4 font-semibold text-primary\">Rabies 3-Year</td>\n<td class=\"py-4 px-4 text-on-surface-variant\">Oct 12, 2023</td>\n<td class=\"py-4 px-4\">\n<span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-fixed text-on-primary-fixed-variant\">\n                                        Oct 11, 2026\n                                    </span>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"py-4 px-4 font-semibold text-primary\">DHPP (Distemper)</td>\n<td class=\"py-4 px-4 text-on-surface-variant\">Jan 05, 2024</td>\n<td class=\"py-4 px-4\">\n<span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-fixed text-on-primary-fixed-variant\">\n                                        Jan 04, 2025\n                                    </span>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"py-4 px-4 font-semibold text-primary\">Bordetella</td>\n<td class=\"py-4 px-4 text-on-surface-variant\">Mar 15, 2024</td>\n<td class=\"py-4 px-4\">\n<span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-tertiary-fixed text-on-tertiary-fixed-variant\">\n                                        Sep 15, 2024\n                                    </span>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"py-4 px-4 font-semibold text-primary\">Leptospirosis</td>\n<td class=\"py-4 px-4 text-on-surface-variant\">Jan 05, 2024</td>\n<td class=\"py-4 px-4\">\n<span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-fixed text-on-primary-fixed-variant\">\n                                        Jan 04, 2025\n                                    </span>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"bg-secondary/5 rounded-xl p-4 flex gap-4 items-start border border-secondary/10\">\n<span class=\"material-symbols-outlined text-secondary\" data-icon=\"info\">info</span>\n<p class=\"text-xs text-on-secondary-container font-medium leading-relaxed\">\n                        This digital document is a verified copy of medical records on file at Kindred Tail Veterinary Clinic. It is valid for international travel when accompanied by an USDA-accredited veterinarian's signature.\n                    </p>\n</div>\n</div>\n</section>\n<!-- Signature Space -->\n<div class=\"mt-8 flex justify-end px-4\">\n<div class=\"text-right\">\n<div class=\"font-['Plus_Jakarta_Sans'] italic text-2xl text-on-surface-variant/40 mb-1\">Dr. Sarah Miller</div>\n<div class=\"h-px w-48 bg-outline-variant mb-2\"></div>\n<p class=\"font-label text-xs uppercase tracking-widest text-on-surface-variant\">Authorized Signatory</p>\n</div>\n</div>\n</main>\n<!-- Bottom Navigation (Labels and Action) -->\n<div class=\"fixed bottom-0 left-0 w-full z-50\">\n<!-- Floating Primary Action Button (Massive Blue) -->\n<div class=\"absolute bottom-24 left-1/2 -translate-x-1/2 w-full max-w-sm px-4\">\n<button class=\"w-full h-16 bg-secondary text-on-secondary rounded-full shadow-lg flex items-center justify-center gap-3 active:scale-[0.98] transition-transform group\">\n<span class=\"material-symbols-outlined text-2xl group-active:translate-y-0.5 transition-transform\" data-icon=\"ios_share\">ios_share</span>\n<span class=\"font-headline font-bold text-lg tracking-wide uppercase\">Share / Print Passport</span>\n</button>\n</div>\n<!-- BottomNavBar Shell -->\n<nav class=\"bg-[#ffffff] dark:bg-[#191d0e] shadow-[0px_-4px_16px_rgba(25,29,14,0.04)] rounded-t-[1.5rem] border-t border-[#bec9c0]/20 flex justify-around items-center px-6 pb-6 pt-3\">\n<button class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-[#bec9c0] hover:bg-[#f2f6dd] dark:hover:bg-emerald-900/40 p-2 rounded-xl transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"download\">download</span>\n<span class=\"font-['Manrope'] font-medium text-[10px] uppercase tracking-wider mt-1\">Download</span>\n</button>\n<button class=\"flex flex-col items-center justify-center bg-[#a1f4c8] dark:bg-[#005236] text-[#005236] dark:text-[#a1f4c8] rounded-full px-5 py-1\">\n<span class=\"material-symbols-outlined\" data-icon=\"share\">share</span>\n<span class=\"font-['Manrope'] font-medium text-[10px] uppercase tracking-wider\">Share</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-[#bec9c0] hover:bg-[#f2f6dd] dark:hover:bg-emerald-900/40 p-2 rounded-xl transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"print\">print</span>\n<span class=\"font-['Manrope'] font-medium text-[10px] uppercase tracking-wider mt-1\">Print</span>\n</button>\n</nav>\n</div>\n</body></html>"}
