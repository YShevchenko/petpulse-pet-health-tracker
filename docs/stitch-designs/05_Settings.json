{"screenId":"8829038c15d84887a15a4884618418c5","projectId":"3066203392880845333","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>PetPulse - Settings</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Manrope:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"tertiary-fixed\": \"#ffdf96\",\n              \"tertiary-container\": \"#8e711f\",\n              \"on-background\": \"#191d0e\",\n              \"primary-container\": \"#30835f\",\n              \"primary\": \"#0b6947\",\n              \"on-error\": \"#ffffff\",\n              \"tertiary\": \"#735802\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"inverse-surface\": \"#2e3222\",\n              \"outline\": \"#6f7a72\",\n              \"secondary\": \"#2b6485\",\n              \"error\": \"#ba1a1a\",\n              \"secondary-fixed-dim\": \"#98cdf2\",\n              \"secondary-fixed\": \"#c7e7ff\",\n              \"outline-variant\": \"#bec9c0\",\n              \"on-secondary-container\": \"#255f80\",\n              \"surface-tint\": \"#116c4a\",\n              \"on-tertiary-fixed\": \"#251a00\",\n              \"inverse-primary\": \"#86d7ad\",\n              \"primary-fixed\": \"#a1f4c8\",\n              \"tertiary-fixed-dim\": \"#e7c268\",\n              \"on-primary-fixed\": \"#002113\",\n              \"background\": \"#f7fce3\",\n              \"surface\": \"#f7fce3\",\n              \"surface-dim\": \"#d8dcc4\",\n              \"on-tertiary-fixed-variant\": \"#5a4400\",\n              \"on-surface\": \"#191d0e\",\n              \"on-primary-container\": \"#f5fff6\",\n              \"on-tertiary\": \"#ffffff\",\n              \"on-primary\": \"#ffffff\",\n              \"surface-container-highest\": \"#e0e5cc\",\n              \"primary-fixed-dim\": \"#86d7ad\",\n              \"on-error-container\": \"#93000a\",\n              \"on-tertiary-container\": \"#fffbff\",\n              \"surface-container\": \"#ecf0d8\",\n              \"secondary-container\": \"#a3d8fe\",\n              \"on-primary-fixed-variant\": \"#005236\",\n              \"on-surface-variant\": \"#3f4943\",\n              \"on-secondary-fixed\": \"#001e2e\",\n              \"surface-container-high\": \"#e6ebd2\",\n              \"on-secondary\": \"#ffffff\",\n              \"on-secondary-fixed-variant\": \"#064c6b\",\n              \"inverse-on-surface\": \"#eff3da\",\n              \"surface-variant\": \"#e0e5cc\",\n              \"surface-container-low\": \"#f2f6dd\",\n              \"error-container\": \"#ffdad6\",\n              \"surface-bright\": \"#f7fce3\"\n            },\n            fontFamily: {\n              \"headline\": [\"Plus Jakarta Sans\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Manrope\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            background-color: #f7fce3;\n            color: #191d0e;\n            font-family: 'Manrope', sans-serif;\n        }\n        .hide-scrollbar::-webkit-scrollbar {\n            display: none;\n        }\n        .hide-scrollbar {\n            -ms-overflow-style: none;\n            scrollbar-width: none;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface selection:bg-primary-fixed selection:text-on-primary-fixed-variant\">\n<!-- TopAppBar -->\n<header class=\"fixed top-0 w-full z-50 bg-[#f7fce3]/80 backdrop-blur-xl flex items-center justify-between px-6 py-4 w-full\">\n<div class=\"flex items-center gap-4\">\n<button class=\"active:scale-95 transition-transform duration-200 text-[#0b6947] hover:opacity-80 transition-opacity\">\n<span class=\"material-symbols-outlined\">arrow_back</span>\n</button>\n<h1 class=\"font-['Plus_Jakarta_Sans'] font-semibold text-lg text-[#0b6947]\">Settings</h1>\n</div>\n<div class=\"text-[#0b6947] font-bold text-xl font-headline tracking-tight\">PetPulse</div>\n</header>\n<main class=\"pt-24 pb-32 px-6 max-w-2xl mx-auto space-y-8\">\n<!-- Profile Switcher Section -->\n<section class=\"space-y-4\">\n<h2 class=\"font-headline font-bold text-on-surface-variant text-sm uppercase tracking-widest px-1\">Active Pet</h2>\n<div class=\"flex items-center gap-6 overflow-x-auto hide-scrollbar py-2\">\n<!-- Luna (Selected) -->\n<div class=\"flex flex-col items-center gap-3 shrink-0\">\n<div class=\"relative\">\n<div class=\"p-1 rounded-full ring-2 ring-primary ring-offset-4 ring-offset-surface\">\n<img alt=\"Luna the cat\" class=\"w-16 h-16 rounded-full object-cover\" data-alt=\"Close-up portrait of a fluffy white and grey cat with bright green eyes resting on a soft blanket\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCyUryre5yKqdIkguqrDBLjgUcuYmyBaskH_hFil0IGOPBD2tmHRXvddkt7quZ4EvhhVmT8S4croF5ornmX8bBNErcivbmjIE83trxq1n2wYBwCn6Zsz97TbRvg40ZLENwV0iStYV4wBLUz-6hpcHNLFjzLBg5mf5TCNCwWrPEhP0-qIsPOY8Gk1D_GNYuFboeBfAwl2pyneL38Zjb4YpaRelVf8Gx6M-B5qNfx34WYGX4krCT6xfYTppSVqxCu5bYFtarO-6uy70w\"/>\n</div>\n<div class=\"absolute -bottom-1 -right-1 bg-primary text-on-primary rounded-full p-0.5 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-[16px]\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n</div>\n</div>\n<span class=\"font-headline font-bold text-on-surface text-sm\">Luna</span>\n</div>\n<!-- Cooper -->\n<div class=\"flex flex-col items-center gap-3 shrink-0 opacity-60 hover:opacity-100 transition-opacity\">\n<div class=\"p-1 rounded-full\">\n<img alt=\"Cooper the dog\" class=\"w-16 h-16 rounded-full object-cover grayscale-[20%]\" data-alt=\"Golden Retriever puppy sitting happily in a green field under soft morning sunlight\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB2QfhL_MXk5RsZckI6VAJjYAmiW3NXdixrDGRpCJb2plB7a2q7I-eKU5ON_Zba-ZsSlx_3dUnnNxySjpOr9T3Ot1PEjM0hlQb_fTctQT_h90PH0_-sl7aE6uEN287_sYSz2cPeCzPADsEwl2rz7p09zYeIDl1Ql5963Wq0HtY8iPL7EIb7ppslwNFPkXmltPJ4mtQLhiLebpKzUW_JyI2rhujupue1x9JhB0m2MslSX955DIP6J4Uj06j-kwE4lB-_dPpKmgQPsxg\"/>\n</div>\n<span class=\"font-headline font-medium text-on-surface-variant text-sm\">Cooper</span>\n</div>\n<!-- Add New -->\n<button class=\"flex flex-col items-center gap-3 shrink-0 active:scale-95 transition-transform\">\n<div class=\"w-16 h-16 rounded-full border-2 border-dashed border-outline-variant flex items-center justify-center bg-surface-container-low\">\n<span class=\"material-symbols-outlined text-outline\">add</span>\n</div>\n<span class=\"font-headline font-medium text-outline text-sm\">Add Pet</span>\n</button>\n</div>\n</section>\n<!-- Premium Feature Card -->\n<section class=\"relative overflow-hidden bg-primary-container text-on-primary-container p-6 rounded-[1.5rem] shadow-lg shadow-primary/10\">\n<div class=\"relative z-10 flex flex-col gap-4\">\n<div class=\"flex justify-between items-start\">\n<div class=\"space-y-1\">\n<span class=\"inline-block bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-wider\">Pro Tier</span>\n<h3 class=\"font-headline font-extrabold text-2xl tracking-tight\">Premium Upgrade</h3>\n</div>\n<span class=\"material-symbols-outlined text-4xl opacity-40\">stars</span>\n</div>\n<p class=\"font-body text-primary-fixed/90 text-sm leading-relaxed max-w-[80%]\">\n                    Unlock Multiple Pets &amp; PDF Passports for $4.99/mo. Keep all your companions' records in one digital sanctuary.\n                </p>\n<button class=\"bg-surface-container-lowest text-primary font-headline font-bold py-3 px-6 rounded-full w-fit hover:bg-primary-fixed transition-colors active:scale-95 duration-200\">\n                    Upgrade Now\n                </button>\n</div>\n<!-- Decorative circle -->\n<div class=\"absolute -right-12 -bottom-12 w-48 h-48 bg-primary/20 rounded-full blur-3xl\"></div>\n</section>\n<!-- Setting Options List -->\n<section class=\"space-y-2\">\n<h2 class=\"font-headline font-bold text-on-surface-variant text-sm uppercase tracking-widest px-1 mb-4\">General Settings</h2>\n<div class=\"bg-surface-container-low rounded-[1.5rem] overflow-hidden\">\n<!-- Notifications -->\n<div class=\"flex items-center justify-between p-4 hover:bg-surface-container-high transition-colors cursor-pointer group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-surface-container-lowest rounded-xl flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">notifications_active</span>\n</div>\n<span class=\"font-headline font-semibold text-on-surface\">App Notifications</span>\n</div>\n<div class=\"w-10 h-6 bg-primary rounded-full relative flex items-center px-1\">\n<div class=\"w-4 h-4 bg-white rounded-full ml-auto\"></div>\n</div>\n</div>\n<!-- Export Data -->\n<div class=\"flex items-center justify-between p-4 hover:bg-surface-container-high transition-colors cursor-pointer group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-surface-container-lowest rounded-xl flex items-center justify-center text-secondary\">\n<span class=\"material-symbols-outlined\">ios_share</span>\n</div>\n<span class=\"font-headline font-semibold text-on-surface\">Export Data</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:translate-x-1 transition-transform\">chevron_right</span>\n</div>\n<!-- Import Data -->\n<div class=\"flex items-center justify-between p-4 hover:bg-surface-container-high transition-colors cursor-pointer group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-surface-container-lowest rounded-xl flex items-center justify-center text-secondary\">\n<span class=\"material-symbols-outlined\">file_download</span>\n</div>\n<span class=\"font-headline font-semibold text-on-surface\">Import Data</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:translate-x-1 transition-transform\">chevron_right</span>\n</div>\n<!-- Privacy -->\n<div class=\"flex items-center justify-between p-4 hover:bg-surface-container-high transition-colors cursor-pointer group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-surface-container-lowest rounded-xl flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">shield_person</span>\n</div>\n<span class=\"font-headline font-semibold text-on-surface\">Privacy &amp; Security</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:translate-x-1 transition-transform\">chevron_right</span>\n</div>\n</div>\n</section>\n<!-- Help Section -->\n<section class=\"space-y-2\">\n<h2 class=\"font-headline font-bold text-on-surface-variant text-sm uppercase tracking-widest px-1 mb-4\">Support</h2>\n<div class=\"bg-surface-container-low rounded-[1.5rem] overflow-hidden\">\n<div class=\"flex items-center justify-between p-4 hover:bg-surface-container-high transition-colors cursor-pointer group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-surface-container-lowest rounded-xl flex items-center justify-center text-tertiary\">\n<span class=\"material-symbols-outlined\">help</span>\n</div>\n<span class=\"font-headline font-semibold text-on-surface\">Help &amp; Support</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:translate-x-1 transition-transform\">chevron_right</span>\n</div>\n<div class=\"flex items-center justify-between p-4 hover:bg-surface-container-high transition-colors cursor-pointer group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-surface-container-lowest rounded-xl flex items-center justify-center text-error\">\n<span class=\"material-symbols-outlined\">logout</span>\n</div>\n<span class=\"font-headline font-semibold text-error\">Log Out</span>\n</div>\n</div>\n</div>\n</section>\n<div class=\"text-center py-4\">\n<p class=\"text-outline-variant text-xs font-label\">PetPulse Version 2.4.1 (Build 882)</p>\n</div>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-[#ffffff] dark:bg-[#191d0e] rounded-t-[1.5rem] shadow-[0px_-8px_24px_rgba(25,29,14,0.06)] z-50\">\n<div class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-[#bec9c0] px-4 py-1 hover:bg-[#f2f6dd] dark:hover:bg-[#3f4943] rounded-full active:scale-90 transition-all duration-200\">\n<span class=\"material-symbols-outlined\">health_and_safety</span>\n<span class=\"font-['Manrope'] text-[12px] font-medium\">Health</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-[#bec9c0] px-4 py-1 hover:bg-[#f2f6dd] dark:hover:bg-[#3f4943] rounded-full active:scale-90 transition-all duration-200\">\n<span class=\"material-symbols-outlined\">monitor_heart</span>\n<span class=\"font-['Manrope'] text-[12px] font-medium\">Vitals</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-[#bec9c0] px-4 py-1 hover:bg-[#f2f6dd] dark:hover:bg-[#3f4943] rounded-full active:scale-90 transition-all duration-200\">\n<span class=\"material-symbols-outlined\">potted_plant</span>\n<span class=\"font-['Manrope'] text-[12px] font-medium\">Care</span>\n</div>\n<!-- Profile Active -->\n<div class=\"flex flex-col items-center justify-center bg-[#a1f4c8] dark:bg-[#005236] text-[#005236] dark:text-[#a1f4c8] rounded-full px-4 py-1 active:scale-90 transition-all duration-200\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">person</span>\n<span class=\"font-['Manrope'] text-[12px] font-medium\">Profile</span>\n</div>\n</nav>\n</body></html>"}
