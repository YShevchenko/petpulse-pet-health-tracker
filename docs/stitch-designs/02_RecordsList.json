{"screenId":"89896d35de3d49be8877333f832d316a","projectId":"3066203392880845333","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>PetPulse - Vaccine Records</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Manrope:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-secondary-fixed-variant\": \"#064c6b\",\n              \"primary-fixed-dim\": \"#86d7ad\",\n              \"on-background\": \"#191d0e\",\n              \"tertiary-fixed-dim\": \"#e7c268\",\n              \"surface-container-high\": \"#e6ebd2\",\n              \"surface-variant\": \"#e0e5cc\",\n              \"error\": \"#ba1a1a\",\n              \"on-tertiary-container\": \"#fffbff\",\n              \"tertiary-container\": \"#8e711f\",\n              \"tertiary-fixed\": \"#ffdf96\",\n              \"surface-bright\": \"#f7fce3\",\n              \"primary\": \"#0b6947\",\n              \"outline-variant\": \"#bec9c0\",\n              \"on-tertiary\": \"#ffffff\",\n              \"secondary\": \"#2b6485\",\n              \"inverse-on-surface\": \"#eff3da\",\n              \"surface-container\": \"#ecf0d8\",\n              \"surface-container-highest\": \"#e0e5cc\",\n              \"background\": \"#f7fce3\",\n              \"on-error-container\": \"#93000a\",\n              \"on-secondary-fixed\": \"#001e2e\",\n              \"inverse-primary\": \"#86d7ad\",\n              \"secondary-fixed-dim\": \"#98cdf2\",\n              \"secondary-fixed\": \"#c7e7ff\",\n              \"on-error\": \"#ffffff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"on-surface\": \"#191d0e\",\n              \"primary-fixed\": \"#a1f4c8\",\n              \"on-secondary\": \"#ffffff\",\n              \"tertiary\": \"#735802\",\n              \"surface\": \"#f7fce3\",\n              \"on-tertiary-fixed\": \"#251a00\",\n              \"on-primary-container\": \"#f5fff6\",\n              \"error-container\": \"#ffdad6\",\n              \"outline\": \"#6f7a72\",\n              \"secondary-container\": \"#a3d8fe\",\n              \"primary-container\": \"#30835f\",\n              \"on-tertiary-fixed-variant\": \"#5a4400\",\n              \"on-primary-fixed-variant\": \"#005236\",\n              \"on-primary\": \"#ffffff\",\n              \"inverse-surface\": \"#2e3222\",\n              \"on-primary-fixed\": \"#002113\",\n              \"surface-tint\": \"#116c4a\",\n              \"surface-dim\": \"#d8dcc4\",\n              \"surface-container-low\": \"#f2f6dd\",\n              \"on-surface-variant\": \"#3f4943\",\n              \"on-secondary-container\": \"#255f80\"\n            },\n            fontFamily: {\n              \"headline\": [\"Plus Jakarta Sans\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Manrope\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n      .material-symbols-outlined {\n        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n      }\n      body {\n        background-color: #f7fce3;\n        font-family: 'Manrope', sans-serif;\n      }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-background min-h-screen pb-24\">\n<!-- TopAppBar -->\n<header class=\"sticky top-0 w-full z-50 bg-[#f7fce3]/80 backdrop-blur-xl shadow-[0_8px_24px_rgba(25,29,14,0.06)] flex items-center justify-between px-6 py-4\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-[#0b6947] hover:opacity-80 transition-opacity active:scale-95 duration-200 cursor-pointer\" data-icon=\"arrow_back\">arrow_back</span>\n<h1 class=\"font-headline font-bold text-lg text-[#0b6947] tracking-tight\">PetPulse</h1>\n</div>\n<span class=\"material-symbols-outlined text-[#0b6947] hover:opacity-80 transition-opacity active:scale-95 duration-200 cursor-pointer\" data-icon=\"settings\">settings</span>\n</header>\n<main class=\"px-6 py-8 max-w-md mx-auto\">\n<!-- Header Section -->\n<div class=\"mb-8\">\n<div class=\"flex items-center gap-3 mb-2\">\n<div class=\"w-12 h-12 rounded-full overflow-hidden bg-surface-container-high\">\n<img alt=\"Pet Portrait\" class=\"w-full h-full object-cover\" data-alt=\"Close-up portrait of a friendly golden retriever dog with a soft blurred garden background and natural sunlight\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAeveds1RMhnMv19gtofPpay4SohZQc2vTVfcFjkf-fE-rjQtzxBdT9mcEETxS08MpGSw6FJoz0YC2HITU1Cwt9V5dgCX2KMJeOUWajCr3P3AhLQAsHR4-svtX-8IFQbZHr6JDG6-iyzZV96ncRGnPvRaPYUjfFvV7qGiyMoItxExC2RzYJmcsqhtObBfhCObSiRrSJpwN9jv85yW3XPUchhCTz6GFbHv54NNIxajIQ9WSHEdvhfvrZo0hIqby4Vmy3yGPFgWFL9dc\"/>\n</div>\n<div>\n<h2 class=\"font-headline font-extrabold text-2xl text-on-surface tracking-tight\">Vaccine Records</h2>\n<p class=\"font-body text-sm text-on-surface-variant\">Oliver's Health History</p>\n</div>\n</div>\n</div>\n<!-- Bento Stats Grid (Specialized Component: The Health Spark style) -->\n<div class=\"grid grid-cols-2 gap-4 mb-8\">\n<div class=\"bg-surface-container-lowest p-5 rounded-[1.5rem] shadow-[0_8px_24px_rgba(25,29,14,0.04)]\">\n<p class=\"font-body text-[10px] uppercase tracking-wider text-on-surface-variant font-bold mb-1\">Status</p>\n<div class=\"flex items-center gap-2\">\n<div class=\"w-2 h-2 rounded-full bg-primary animate-pulse\"></div>\n<span class=\"font-headline font-bold text-primary\">Protected</span>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest p-5 rounded-[1.5rem] shadow-[0_8px_24px_rgba(25,29,14,0.04)]\">\n<p class=\"font-body text-[10px] uppercase tracking-wider text-on-surface-variant font-bold mb-1\">Due Next</p>\n<span class=\"font-headline font-bold text-on-surface\">12 Oct 2024</span>\n</div>\n</div>\n<!-- Vaccine List -->\n<div class=\"space-y-4\">\n<!-- Rabies Card -->\n<div class=\"bg-surface-container-lowest p-5 rounded-[1.5rem] flex items-center justify-between shadow-[0_4px_12px_rgba(25,29,14,0.03)] group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-xl bg-primary-fixed flex items-center justify-center text-on-primary-fixed-variant\">\n<span class=\"material-symbols-outlined\" data-icon=\"vaccines\">vaccines</span>\n</div>\n<div>\n<h3 class=\"font-headline font-bold text-on-surface\">Rabies</h3>\n<p class=\"font-body text-xs text-on-surface-variant\">Administered: 12 Oct 2023</p>\n</div>\n</div>\n<div class=\"flex flex-col items-end gap-1\">\n<span class=\"bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight flex items-center gap-1\">\n<span class=\"material-symbols-outlined text-[14px]\" data-icon=\"check_circle\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n                        Up-to-date\n                    </span>\n<p class=\"text-[10px] text-on-surface-variant font-medium\">Valid for 3 years</p>\n</div>\n</div>\n<!-- Bordetella Card (Urgent Style) -->\n<div class=\"bg-surface-container-lowest p-5 rounded-[1.5rem] flex items-center justify-between shadow-[0_4px_12px_rgba(25,29,14,0.03)]\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-xl bg-tertiary-fixed flex items-center justify-center text-on-tertiary-fixed-variant\">\n<span class=\"material-symbols-outlined\" data-icon=\"coronavirus\">coronavirus</span>\n</div>\n<div>\n<h3 class=\"font-headline font-bold text-on-surface\">Bordetella</h3>\n<p class=\"font-body text-xs text-on-surface-variant\">Administered: 15 Mar 2023</p>\n</div>\n</div>\n<div class=\"flex flex-col items-end gap-1\">\n<span class=\"bg-error-container text-on-error-container px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight flex items-center gap-1\">\n<span class=\"material-symbols-outlined text-[14px]\" data-icon=\"error\" style=\"font-variation-settings: 'FILL' 1;\">error</span>\n                        Due Soon\n                    </span>\n<p class=\"text-[10px] text-error font-medium\">Due in 5 days</p>\n</div>\n</div>\n<!-- Distemper Card -->\n<div class=\"bg-surface-container-lowest p-5 rounded-[1.5rem] flex items-center justify-between shadow-[0_4px_12px_rgba(25,29,14,0.03)]\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-xl bg-secondary-container flex items-center justify-center text-on-secondary-container\">\n<span class=\"material-symbols-outlined\" data-icon=\"medical_services\">medical_services</span>\n</div>\n<div>\n<h3 class=\"font-headline font-bold text-on-surface\">DHPP</h3>\n<p class=\"font-body text-xs text-on-surface-variant\">Administered: 12 Oct 2023</p>\n</div>\n</div>\n<div class=\"flex flex-col items-end gap-1\">\n<span class=\"bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight flex items-center gap-1\">\n<span class=\"material-symbols-outlined text-[14px]\" data-icon=\"check_circle\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n                        Up-to-date\n                    </span>\n<p class=\"text-[10px] text-on-surface-variant font-medium\">Annual booster</p>\n</div>\n</div>\n<!-- Lyme Disease Card -->\n<div class=\"bg-surface-container-lowest p-5 rounded-[1.5rem] flex items-center justify-between shadow-[0_4px_12px_rgba(25,29,14,0.03)]\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-xl bg-surface-variant flex items-center justify-center text-on-surface-variant\">\n<span class=\"material-symbols-outlined\" data-icon=\"bug_report\">bug_report</span>\n</div>\n<div>\n<h3 class=\"font-headline font-bold text-on-surface\">Lyme Disease</h3>\n<p class=\"font-body text-xs text-on-surface-variant\">Administered: 20 May 2023</p>\n</div>\n</div>\n<div class=\"flex flex-col items-end gap-1\">\n<span class=\"bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight flex items-center gap-1\">\n<span class=\"material-symbols-outlined text-[14px]\" data-icon=\"check_circle\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n                        Up-to-date\n                    </span>\n<p class=\"text-[10px] text-on-surface-variant font-medium\">Valid until May 2024</p>\n</div>\n</div>\n</div>\n<!-- Professional Tip Card -->\n<div class=\"mt-8 bg-primary-container p-6 rounded-[2rem] relative overflow-hidden\">\n<div class=\"relative z-10\">\n<h4 class=\"font-headline font-bold text-on-primary-container mb-1\">Vet Consultation</h4>\n<p class=\"font-body text-sm text-on-primary-container/80 mb-4\">Book a wellness check to keep Oliver's records current.</p>\n<button class=\"bg-on-primary-container text-primary-container px-6 py-2 rounded-full font-bold text-sm active:scale-95 duration-150\">Schedule Now</button>\n</div>\n<!-- Decorative circle -->\n<div class=\"absolute -bottom-6 -right-6 w-32 h-32 bg-primary rounded-full opacity-20\"></div>\n</div>\n</main>\n<!-- Floating Action Button -->\n<button class=\"fixed bottom-28 right-6 w-14 h-14 bg-primary text-on-primary rounded-full shadow-[0_8px_24px_rgba(11,105,71,0.3)] flex items-center justify-center active:scale-90 transition-transform duration-150 z-40\">\n<span class=\"material-symbols-outlined text-3xl\" data-icon=\"add\">add</span>\n</button>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-[#ffffff] shadow-[0_-4px_20px_rgba(25,29,14,0.04)] rounded-t-[1.5rem]\">\n<a class=\"flex flex-col items-center justify-center text-[#3f4943] px-5 py-2 hover:bg-[#f2f6dd] transition-colors active:scale-90 duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"pets\">pets</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-1\">Health</span>\n</a>\n<a class=\"flex flex-col items-center justify-center bg-[#a1f4c8] text-[#005236] rounded-full px-5 py-2 active:scale-90 duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"monitor_heart\" style=\"font-variation-settings: 'FILL' 1;\">monitor_heart</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-1\">Vitals</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#3f4943] px-5 py-2 hover:bg-[#f2f6dd] transition-colors active:scale-90 duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"medical_services\">medical_services</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-1\">Care</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#3f4943] px-5 py-2 hover:bg-[#f2f6dd] transition-colors active:scale-90 duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-1\">Profile</span>\n</a>\n</nav>\n</body></html>"}
