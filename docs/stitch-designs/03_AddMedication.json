{"screenId":"de0a688907804375aefcec9d7f6bc3eb","projectId":"3066203392880845333","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Add Medication - Kindred Tail</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Manrope:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-tertiary-container\": \"#fffbff\",\n              \"surface-variant\": \"#e0e5cc\",\n              \"error\": \"#ba1a1a\",\n              \"surface-container-high\": \"#e6ebd2\",\n              \"on-secondary-fixed-variant\": \"#064c6b\",\n              \"primary-fixed-dim\": \"#86d7ad\",\n              \"on-background\": \"#191d0e\",\n              \"tertiary-fixed-dim\": \"#e7c268\",\n              \"secondary\": \"#2b6485\",\n              \"inverse-on-surface\": \"#eff3da\",\n              \"surface-container\": \"#ecf0d8\",\n              \"tertiary-fixed\": \"#ffdf96\",\n              \"surface-bright\": \"#f7fce3\",\n              \"primary\": \"#0b6947\",\n              \"outline-variant\": \"#bec9c0\",\n              \"on-tertiary\": \"#ffffff\",\n              \"tertiary-container\": \"#8e711f\",\n              \"primary-fixed\": \"#a1f4c8\",\n              \"on-secondary\": \"#ffffff\",\n              \"secondary-fixed-dim\": \"#98cdf2\",\n              \"secondary-fixed\": \"#c7e7ff\",\n              \"on-error\": \"#ffffff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"on-surface\": \"#191d0e\",\n              \"on-error-container\": \"#93000a\",\n              \"on-secondary-fixed\": \"#001e2e\",\n              \"inverse-primary\": \"#86d7ad\",\n              \"surface-container-highest\": \"#e0e5cc\",\n              \"background\": \"#f7fce3\",\n              \"surface-tint\": \"#116c4a\",\n              \"surface-dim\": \"#d8dcc4\",\n              \"surface-container-low\": \"#f2f6dd\",\n              \"on-surface-variant\": \"#3f4943\",\n              \"on-secondary-container\": \"#255f80\",\n              \"primary-container\": \"#30835f\",\n              \"on-tertiary-fixed-variant\": \"#5a4400\",\n              \"on-primary-fixed-variant\": \"#005236\",\n              \"on-primary\": \"#ffffff\",\n              \"inverse-surface\": \"#2e3222\",\n              \"on-primary-fixed\": \"#002113\",\n              \"error-container\": \"#ffdad6\",\n              \"outline\": \"#6f7a72\",\n              \"secondary-container\": \"#a3d8fe\",\n              \"tertiary\": \"#735802\",\n              \"surface\": \"#f7fce3\",\n              \"on-tertiary-fixed\": \"#251a00\",\n              \"on-primary-container\": \"#f5fff6\"\n            },\n            fontFamily: {\n              \"headline\": [\"Plus Jakarta Sans\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Manrope\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n      .material-symbols-outlined {\n        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n      }\n      .no-scrollbar::-webkit-scrollbar { display: none; }\n      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-surface min-h-screen flex flex-col items-center justify-center\">\n<!-- Background Mock Content (To simulate depth) -->\n<main class=\"w-full max-w-xl mx-auto p-6 space-y-8 opacity-40 blur-sm pointer-events-none\">\n<header class=\"flex justify-between items-center\">\n<div>\n<h1 class=\"font-headline text-2xl font-extrabold text-primary tracking-tight\">Dashboard</h1>\n<p class=\"text-on-surface-variant font-medium\">Monday, June 12</p>\n</div>\n<div class=\"w-12 h-12 rounded-full bg-surface-container-highest overflow-hidden\">\n<img class=\"w-full h-full object-cover\" data-alt=\"close-up portrait of a happy golden retriever dog smiling with soft sunlight\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuA0JF2bqiDsfhEx_NUMrISiysseHsZpMfIbzoP2vtLvudCprzQS2K4D_EfNCyHsBIE9EzVpTHlRzAdRDGcYbDM5JjIdf9CUzXR0AEblT-XmTlHBOJm_4piXrrZem0RC-3_SKwHyPoffBBLCZQ84TIHzPsbZZKv5EB5fyd2L_HZX8PLcpP4AV7ftvU0YzWJqFS97gdY5otBbF0ZGIVVI2AxKNMrZ7D8icdzNSoMkoNOsi7NB2yvRJGJb2Vs1kiiMJePF4iLxOB1Lo5E\"/>\n</div>\n</header>\n<section class=\"space-y-4\">\n<div class=\"h-32 bg-surface-container-lowest rounded-xl shadow-none\"></div>\n<div class=\"grid grid-cols-2 gap-4\">\n<div class=\"h-40 bg-surface-container-low rounded-xl\"></div>\n<div class=\"h-40 bg-surface-container-low rounded-xl\"></div>\n</div>\n</section>\n</main>\n<!-- Modal Backdrop -->\n<div class=\"fixed inset-0 bg-inverse-surface/10 backdrop-blur-sm z-40\"></div>\n<!-- Bottom Sheet Modal Content -->\n<div class=\"fixed inset-x-0 bottom-0 z-50 flex justify-center items-end\">\n<div class=\"bg-surface-container-lowest w-full max-w-xl rounded-t-[2.5rem] shadow-[0_-8px_24px_rgba(25,29,14,0.06)] overflow-hidden flex flex-col\">\n<!-- Handle -->\n<div class=\"flex justify-center pt-4 pb-2\">\n<div class=\"w-12 h-1.5 bg-surface-variant rounded-full\"></div>\n</div>\n<!-- TopAppBar Internal to Modal -->\n<nav class=\"flex items-center justify-between px-6 py-4 w-full\">\n<div class=\"flex items-center space-x-4\">\n<button class=\"text-on-surface hover:opacity-80 transition-opacity active:scale-95 transition-transform duration-200\">\n<span class=\"material-symbols-outlined\" data-icon=\"close\">close</span>\n</button>\n<h2 class=\"font-headline text-lg font-bold tracking-tight text-on-surface\">Add Medication</h2>\n</div>\n<button class=\"text-primary font-bold text-sm\">Need Help?</button>\n</nav>\n<div class=\"px-6 pb-12 pt-4 space-y-8 overflow-y-auto no-scrollbar max-h-[707px]\">\n<!-- Illustration/Context Card -->\n<div class=\"bg-surface-container-low p-6 rounded-xl flex items-center space-x-4\">\n<div class=\"bg-primary-fixed-dim p-3 rounded-xl\">\n<span class=\"material-symbols-outlined text-on-primary-fixed-variant\" data-icon=\"medication\" style=\"font-variation-settings: 'FILL' 1;\">medication</span>\n</div>\n<div>\n<h3 class=\"font-headline font-bold text-on-surface leading-tight\">Stay Proactive</h3>\n<p class=\"text-on-surface-variant text-sm\">Managing your pet's health is easier with timely reminders.</p>\n</div>\n</div>\n<form class=\"space-y-6\">\n<!-- Medication Name Input -->\n<div class=\"space-y-2\">\n<label class=\"font-headline text-sm font-bold text-on-surface-variant px-1\" for=\"medication_name\">Medication Name</label>\n<div class=\"relative group\">\n<input class=\"w-full bg-surface-container-highest border-b-2 border-transparent border-b-outline-variant/20 focus:border-b-primary focus:ring-0 rounded-t-xl px-4 py-4 font-body transition-all outline-none\" id=\"medication_name\" placeholder=\"Heartworm Preventive...\" type=\"text\"/>\n<span class=\"absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline\" data-icon=\"pill\">pill</span>\n</div>\n</div>\n<!-- Dosage Input -->\n<div class=\"space-y-2\">\n<label class=\"font-headline text-sm font-bold text-on-surface-variant px-1\" for=\"dosage\">Dosage</label>\n<div class=\"relative\">\n<input class=\"w-full bg-surface-container-highest border-b-2 border-transparent border-b-outline-variant/20 focus:border-b-primary focus:ring-0 rounded-t-xl px-4 py-4 font-body transition-all outline-none\" id=\"dosage\" placeholder=\"e.g. 1 Tablet (25mg)\" type=\"text\"/>\n<span class=\"absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline\" data-icon=\"monitor_weight\">monitor_weight</span>\n</div>\n<p class=\"text-[11px] text-outline px-1\">Check the physical label for precise measurement</p>\n</div>\n<!-- Frequency Selector -->\n<div class=\"space-y-2\">\n<label class=\"font-headline text-sm font-bold text-on-surface-variant px-1\">Frequency</label>\n<div class=\"grid grid-cols-2 gap-3\">\n<div class=\"bg-surface-container-low border-2 border-transparent px-4 py-3 rounded-xl flex items-center justify-center space-x-2 transition-all cursor-pointer hover:bg-surface-container-high\">\n<span class=\"material-symbols-outlined text-sm\" data-icon=\"event_repeat\">event_repeat</span>\n<span class=\"text-sm font-bold\">Daily</span>\n</div>\n<div class=\"bg-primary-container border-2 border-primary/20 px-4 py-3 rounded-xl flex items-center justify-center space-x-2 transition-all cursor-pointer\">\n<span class=\"material-symbols-outlined text-sm text-on-primary-container\" data-icon=\"check_circle\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n<span class=\"text-sm font-bold text-on-primary-container\">Monthly</span>\n</div>\n</div>\n<!-- Custom Select Dropdown -->\n<div class=\"relative pt-2\">\n<select class=\"w-full appearance-none bg-surface-container-highest rounded-t-xl px-4 py-4 font-body font-medium focus:ring-0 border-b-2 border-outline-variant/20 outline-none\">\n<option>Repeat every month</option>\n<option>Repeat every 3 months</option>\n<option>Repeat every 6 months</option>\n<option>Specific days</option>\n</select>\n<span class=\"absolute right-4 top-[60%] -translate-y-1/2 material-symbols-outlined pointer-events-none text-on-surface-variant\" data-icon=\"expand_more\">expand_more</span>\n</div>\n</div>\n<!-- Additional Options Bento -->\n<div class=\"grid grid-cols-2 gap-3\">\n<div class=\"bg-surface-container-low p-4 rounded-xl space-y-1 cursor-pointer\">\n<span class=\"material-symbols-outlined text-tertiary\" data-icon=\"notifications_active\">notifications_active</span>\n<p class=\"text-xs font-bold block\">Push Alerts</p>\n<p class=\"text-[10px] text-on-surface-variant\">Enabled</p>\n</div>\n<div class=\"bg-surface-container-low p-4 rounded-xl space-y-1 cursor-pointer\">\n<span class=\"material-symbols-outlined text-secondary\" data-icon=\"history\">history</span>\n<p class=\"text-xs font-bold block\">Reminders</p>\n<p class=\"text-[10px] text-on-surface-variant\">Auto-logs</p>\n</div>\n</div>\n</form>\n<!-- Action Button -->\n<div class=\"pt-4\">\n<button class=\"w-full bg-tertiary text-on-tertiary font-headline font-extrabold text-lg py-5 rounded-full shadow-lg active:scale-95 transition-all flex items-center justify-center space-x-3\">\n<span>Save Reminder</span>\n<span class=\"material-symbols-outlined\" data-icon=\"done_all\">done_all</span>\n</button>\n<p class=\"text-center text-on-surface-variant text-[11px] mt-4 font-medium\">Safe storage for your pet's wellbeing</p>\n</div>\n</div>\n</div>\n</div>\n<!-- Bottom Nav Bar (Shared Component Reference - Only used for visual anchor) -->\n<div class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-white/90 dark:bg-zinc-900/90 backdrop-blur-xl rounded-t-[2rem] z-30 opacity-20 grayscale\">\n<div class=\"flex flex-col items-center justify-center text-emerald-700/60 px-5 py-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"medical_services\">medical_services</span>\n<span class=\"font-manrope text-[11px] font-medium\">Health</span>\n</div>\n<div class=\"flex flex-col items-center justify-center bg-emerald-100 text-emerald-900 rounded-full px-5 py-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"medication\" style=\"font-variation-settings: 'FILL' 1;\">medication</span>\n<span class=\"font-manrope text-[11px] font-medium\">Medication</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-emerald-700/60 px-5 py-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"calendar_today\">calendar_today</span>\n<span class=\"font-manrope text-[11px] font-medium\">Schedule</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-emerald-700/60 px-5 py-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-manrope text-[11px] font-medium\">Profile</span>\n</div>\n</div>\n</body></html>"}
