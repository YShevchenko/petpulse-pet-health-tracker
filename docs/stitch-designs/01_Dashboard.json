{"screenId":"fd6d621cba6e445fbc1589685314a16a","projectId":"3066203392880845333","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>PetPulse - Luna's Health Dashboard</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Manrope:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-error\": \"#ffffff\",\n              \"on-secondary\": \"#ffffff\",\n              \"tertiary\": \"#735802\",\n              \"on-tertiary\": \"#ffffff\",\n              \"primary\": \"#0b6947\",\n              \"on-primary-fixed\": \"#002113\",\n              \"on-secondary-container\": \"#255f80\",\n              \"on-tertiary-fixed-variant\": \"#5a4400\",\n              \"on-tertiary-fixed\": \"#251a00\",\n              \"inverse-surface\": \"#2e3222\",\n              \"secondary-container\": \"#a3d8fe\",\n              \"on-background\": \"#191d0e\",\n              \"tertiary-fixed-dim\": \"#e7c268\",\n              \"secondary\": \"#2b6485\",\n              \"on-primary-container\": \"#f5fff6\",\n              \"tertiary-container\": \"#8e711f\",\n              \"surface-bright\": \"#f7fce3\",\n              \"surface-container-highest\": \"#e0e5cc\",\n              \"inverse-primary\": \"#86d7ad\",\n              \"error-container\": \"#ffdad6\",\n              \"primary-fixed-dim\": \"#86d7ad\",\n              \"on-surface\": \"#191d0e\",\n              \"tertiary-fixed\": \"#ffdf96\",\n              \"primary-fixed\": \"#a1f4c8\",\n              \"primary-container\": \"#30835f\",\n              \"secondary-fixed\": \"#c7e7ff\",\n              \"on-secondary-fixed-variant\": \"#064c6b\",\n              \"on-primary\": \"#ffffff\",\n              \"outline\": \"#6f7a72\",\n              \"inverse-on-surface\": \"#eff3da\",\n              \"background\": \"#f7fce3\",\n              \"on-primary-fixed-variant\": \"#005236\",\n              \"surface\": \"#f7fce3\",\n              \"on-error-container\": \"#93000a\",\n              \"surface-variant\": \"#e0e5cc\",\n              \"on-tertiary-container\": \"#fffbff\",\n              \"outline-variant\": \"#bec9c0\",\n              \"secondary-fixed-dim\": \"#98cdf2\",\n              \"surface-dim\": \"#d8dcc4\",\n              \"surface-container-low\": \"#f2f6dd\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"on-surface-variant\": \"#3f4943\",\n              \"surface-container-high\": \"#e6ebd2\",\n              \"surface-container\": \"#ecf0d8\",\n              \"surface-tint\": \"#116c4a\",\n              \"error\": \"#ba1a1a\",\n              \"on-secondary-fixed\": \"#001e2e\"\n            },\n            fontFamily: {\n              \"headline\": [\"Plus Jakarta Sans\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Manrope\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n      .material-symbols-outlined {\n        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n      }\n      .no-scrollbar::-webkit-scrollbar { display: none; }\n      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-surface selection:bg-primary-fixed-dim min-h-screen pb-32\">\n<!-- TopAppBar -->\n<header class=\"sticky top-0 w-full z-50 bg-[#f7fce3]/80 dark:bg-stone-950/80 backdrop-blur-xl shadow-[0_8px_24px_rgba(25,29,14,0.06)] flex items-center justify-between px-6 py-4 w-full\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-10 h-10 rounded-full overflow-hidden bg-surface-container-highest ring-2 ring-primary-fixed\">\n<img alt=\"Pet Profile Photo\" class=\"w-full h-full object-cover\" data-alt=\"close-up portrait of a friendly golden retriever dog with soft sunlight on its golden fur in a bright outdoor setting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAfwr2mjFyQ3klBJ4jYvM_gGbJIxnSBieornbA9aNvNYPbh7a8UBJ7yEkdIRzdYfhDotjYByJrdfVUGaIZFixvGTQQjNszrtghm7cRTsTb1R8MLwcudavQAMGz7V6YJrIke0f-nX8-Fz0_56RzFlwSWdCMGP7gEiPYBOtb5IEiTYz1avFDqv2IrYATffkgPycZvssMazUjzJr8vABtSjv2AXjB4AuXE22n6V1taEJj3XcCdlresG9haeovoKitnlIERSEamJwBrBck\"/>\n</div>\n<span class=\"font-headline font-extrabold tracking-tight text-[#0b6947] text-lg\">PetPulse</span>\n</div>\n<button class=\"text-[#0b6947] hover:opacity-80 transition-opacity active:scale-95 duration-200\">\n<span class=\"material-symbols-outlined\">settings</span>\n</button>\n</header>\n<main class=\"px-6 pt-6 max-w-2xl mx-auto space-y-8\">\n<!-- Hero Card: Luna -->\n<section class=\"relative overflow-hidden rounded-[2rem] bg-surface-container-lowest shadow-[0_8px_24px_rgba(25,29,14,0.06)]\">\n<div class=\"aspect-[4/3] relative\">\n<img alt=\"Luna\" class=\"w-full h-full object-cover\" data-alt=\"professional high-quality photography of a happy golden retriever dog named Luna sitting on a manicured green lawn at golden hour\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAoSqcn6UASdXLANFlreAMcwdaNQ8qFBd0Zt22FyPw3dAzImTpOij5EcZcRs6WSfDsWtOpAshOYdZ7onb2nlDk1hDj9PaxoNLqog2Pka2dxM5ZjP2kRO59OUpWIJoQBatyKWEykb_EjFy6rqgoYOmYcxLQm5M0-wNB9AZ4n8wzlY78WrnFojHoNhk0xqgB93DC3CiUTOaNNluIGYhDrxKxVE1fYZSHlKSi2EVQgc9RZoExypdxD0RPu-2snBwquVlq6vD_go0fHz7E\"/>\n<div class=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent\"></div>\n<div class=\"absolute bottom-6 left-6 text-white\">\n<h1 class=\"font-headline font-extrabold text-4xl tracking-tight\">Luna</h1>\n<div class=\"flex items-center gap-2 mt-1\">\n<span class=\"w-2 h-2 rounded-full bg-primary-fixed\"></span>\n<p class=\"font-label text-sm font-medium tracking-wide uppercase\">Healthy &amp; Happy</p>\n</div>\n</div>\n</div>\n</section>\n<!-- Status Grid -->\n<section class=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n<!-- Vaccines Card -->\n<div class=\"bg-surface-container-lowest p-6 rounded-[1.5rem] shadow-[0_4px_12px_rgba(25,29,14,0.04)] flex flex-col items-start gap-4\">\n<div class=\"w-12 h-12 rounded-2xl bg-primary-fixed flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-primary-fixed-variant\" style=\"font-variation-settings: 'FILL' 1;\">vaccines</span>\n</div>\n<div>\n<h3 class=\"font-headline font-bold text-on-surface-variant text-sm\">Vaccines</h3>\n<div class=\"mt-1 flex items-center gap-2\">\n<span class=\"text-primary font-bold\">Up to date</span>\n</div>\n</div>\n</div>\n<!-- Medications Card -->\n<div class=\"bg-surface-container-lowest p-6 rounded-[1.5rem] shadow-[0_4px_12px_rgba(25,29,14,0.04)] flex flex-col items-start gap-4\">\n<div class=\"w-12 h-12 rounded-2xl bg-tertiary-fixed flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-tertiary-fixed-variant\" style=\"font-variation-settings: 'FILL' 1;\">prescriptions</span>\n</div>\n<div>\n<h3 class=\"font-headline font-bold text-on-surface-variant text-sm\">Medications</h3>\n<div class=\"mt-1 flex items-center gap-2\">\n<span class=\"text-tertiary font-bold\">1 Due Soon</span>\n</div>\n</div>\n</div>\n<!-- Weight Card -->\n<div class=\"bg-surface-container-lowest p-6 rounded-[1.5rem] shadow-[0_4px_12px_rgba(25,29,14,0.04)] flex flex-col items-start gap-4 md:col-span-1\">\n<div class=\"w-full flex justify-between items-center\">\n<div class=\"w-12 h-12 rounded-2xl bg-secondary-fixed flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-secondary-fixed-variant\" style=\"font-variation-settings: 'FILL' 1;\">monitoring</span>\n</div>\n<span class=\"font-headline font-bold text-on-surface\">32.4 kg</span>\n</div>\n<div class=\"w-full\">\n<h3 class=\"font-headline font-bold text-on-surface-variant text-sm\">Weight</h3>\n<!-- Sparkline SVG -->\n<div class=\"w-full h-10 mt-2\">\n<svg class=\"w-full h-full overflow-visible\" viewbox=\"0 0 100 30\">\n<path d=\"M0,25 Q10,22 20,24 T40,18 T60,20 T80,15 T100,16\" fill=\"none\" stroke=\"#2b6485\" stroke-linecap=\"round\" stroke-width=\"3\"></path>\n</svg>\n</div>\n</div>\n</div>\n</section>\n<!-- Bento Layout for Extra Insights -->\n<section class=\"grid grid-cols-2 gap-4\">\n<div class=\"bg-surface-container-low p-6 rounded-[1.5rem] flex flex-col gap-2\">\n<span class=\"font-label text-xs font-bold text-on-surface-variant tracking-wider uppercase\">Activity</span>\n<span class=\"font-headline font-extrabold text-2xl text-primary\">8.4k <span class=\"text-sm font-medium\">steps</span></span>\n<div class=\"mt-4 bg-surface-container-highest rounded-full h-1.5 w-full\">\n<div class=\"bg-primary h-full w-[84%] rounded-full\"></div>\n</div>\n</div>\n<div class=\"bg-secondary-container/30 p-6 rounded-[1.5rem] flex flex-col justify-between\">\n<div>\n<span class=\"font-label text-xs font-bold text-on-secondary-fixed-variant tracking-wider uppercase\">Vitals</span>\n<p class=\"font-body text-sm mt-1 text-on-surface-variant\">Last check 2h ago</p>\n</div>\n<span class=\"material-symbols-outlined text-secondary text-4xl self-end\" style=\"font-variation-settings: 'FILL' 1;\">monitor_heart</span>\n</div>\n</section>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-[#ffffff] dark:bg-stone-900 rounded-t-[1.5rem] shadow-[0_-4px_20px_rgba(25,29,14,0.04)]\">\n<!-- Health Active -->\n<div class=\"flex flex-col items-center justify-center bg-[#a1f4c8] dark:bg-[#005236] text-[#005236] dark:text-[#a1f4c8] rounded-full px-5 py-2 active:scale-90 duration-150 cursor-pointer\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">pets</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-0.5\">Health</span>\n</div>\n<!-- Vitals -->\n<div class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-stone-400 px-5 py-2 hover:bg-[#f2f6dd] dark:hover:bg-stone-800 transition-colors active:scale-90 duration-150 cursor-pointer\">\n<span class=\"material-symbols-outlined\">monitor_heart</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-0.5\">Vitals</span>\n</div>\n<!-- Care -->\n<div class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-stone-400 px-5 py-2 hover:bg-[#f2f6dd] dark:hover:bg-stone-800 transition-colors active:scale-90 duration-150 cursor-pointer\">\n<span class=\"material-symbols-outlined\">medical_services</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-0.5\">Care</span>\n</div>\n<!-- Profile -->\n<div class=\"flex flex-col items-center justify-center text-[#3f4943] dark:text-stone-400 px-5 py-2 hover:bg-[#f2f6dd] dark:hover:bg-stone-800 transition-colors active:scale-90 duration-150 cursor-pointer\">\n<span class=\"material-symbols-outlined\">person</span>\n<span class=\"font-manrope text-[10px] font-semibold uppercase tracking-wider mt-0.5\">Profile</span>\n</div>\n</nav>\n</body></html>"}
